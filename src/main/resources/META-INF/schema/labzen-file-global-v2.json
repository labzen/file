{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labzen.cn/json-schema/file-global/v2",
  "title": "Global Data Definition Style Schema",
  "description": "数据文件全局定义 Schema",
  "type": "object",
  "properties": {
    "exporting-header-style": {
      "$ref": "#/definitions/Style",
      "description": "全局表头样式定义"
    },
    "exporting-column-style": {
      "$ref": "#/definitions/Style",
      "description": "全局单元格样式定义"
    },
    "width": {
      "type": "integer",
      "minimum": 1,
      "description": "全局默认列宽"
    },
    "exporting": {
      "$ref": "#/definitions/Exporting",
      "description": "导出方向全局定义"
    },
    "importing": {
      "$ref": "#/definitions/Importing",
      "description": "导入方向全局定义"
    }
  },
  "definitions": {
    "Style": {
      "type": "object",
      "properties": {
        "align": {
          "type": "string",
          "enum": [
            "HORIZONTAL",
            "CENTER",
            "LEFT",
            "RIGHT",
            "TOP",
            "BOTTOM",
            "FILL",
            "JUSTIFY",
            "DISTRIBUTED"
          ],
          "description": "对齐方式：HORIZONTAL - 默认水平对齐, CENTER - 居中对齐，可视为水平和垂直的居中, LEFT - 水平左对齐, RIGHT - 水平右对齐, TOP - 垂直上对齐, BOTTOM - 垂直下对齐, FILL - 水平填充对齐, JUSTIFY - 水平和垂直两端对齐, DISTRIBUTED - 水平和垂直分散对齐,"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色，十六进制 RGB 格式，如 #FFFFFF"
        },
        "font": {
          "type": "object",
          "description": "字体样式",
          "properties": {
            "family": {
              "type": "string",
              "description": "字体名称，如 Arial、Microsoft YaHei"
            },
            "size": {
              "type": "integer",
              "minimum": 1,
              "maximum": 72,
              "description": "字体大小，默认13"
            },
            "color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "字体颜色，十六进制 RGB 格式"
            },
            "bold": {
              "type": "boolean",
              "description": "是否加粗"
            },
            "italic": {
              "type": "boolean",
              "description": "是否斜体"
            }
          }
        },
        "wrapped": {
          "type": "boolean",
          "description": "是否自动换行"
        }
      }
    },
    "Exporting": {
      "type": "object",
      "properties": {
        "when-null": {
          "type": "string",
          "description": "当数据为 null 时使用的默认值。支持国际化：使用 ${key} 占位符"
        },
        "when-blank": {
          "type": "string",
          "description": "当数据为空字符串时使用的默认值，仅适用于String类型。支持国际化：使用 ${key} 占位符"
        }
      }
    },
    "Importing": {
      "type": "object",
      "required": [
        "cleansing"
      ],
      "properties": {
        "cleansing": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "description": "全局默认清理器列表"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labzen.cn/file/export-schema.json",
  "title": "Global Data Export Style Schema",
  "description": "数据导出全局样式元数据定义 Schema，仅定义全局的数据样式，不涉及到任何具体的字段信息",
  "type": "object",
  "required": [
    "header",
    "column"
  ],
  "properties": {
    "header": {
      "$ref": "#/definitions/Style",
      "description": "全局表头样式定义"
    },
    "column": {
      "$ref": "#/definitions/Column",
      "description": "全局数据单元格样式定义"
    }
  },
  "definitions": {
    "Style": {
      "type": "object",
      "properties": {
        "align": {
          "type": "string",
          "enum": [
            "HORIZONTAL",
            "CENTER",
            "LEFT",
            "RIGHT",
            "TOP",
            "BOTTOM",
            "FILL",
            "JUSTIFY",
            "DISTRIBUTED"
          ],
          "description": "对齐方式：HORIZONTAL - 默认水平对齐, CENTER - 居中对齐，可视为水平和垂直的居中, LEFT - 水平左对齐, RIGHT - 水平右对齐, TOP - 垂直上对齐, BOTTOM - 垂直下对齐, FILL - 水平填充对齐, JUSTIFY - 水平和垂直两端对齐, DISTRIBUTED - 水平和垂直分散对齐,"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色，十六进制 RGB 格式，如 #FFFFFF"
        },
        "font": {
          "type": "object",
          "description": "字体样式",
          "properties": {
            "family": {
              "type": "string",
              "description": "字体名称，如 Arial、Microsoft YaHei"
            },
            "size": {
              "type": "integer",
              "minimum": 1,
              "maximum": 72,
              "description": "字体大小，默认13"
            },
            "color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "字体颜色，十六进制 RGB 格式"
            },
            "bold": {
              "type": "boolean",
              "description": "是否加粗"
            },
            "italic": {
              "type": "boolean",
              "description": "是否斜体"
            }
          }
        },
        "wrapped": {
          "type": "boolean",
          "description": "是否自动换行"
        }
      }
    },
    "Column": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "全局默认列宽"
        },
        "style": {
          "$ref": "#/definitions/Style",
          "description": "此列的覆盖样式"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labzen.cn/file/export-schema.json",
  "title": "Data Export Schema",
  "description": "数据导出元数据定义 Schema，用于定义数据库映射类导出文件时的列信息、样式、数据转换等配置",
  "type": "object",
  "required": [
    "filename",
    "title",
    "columns"
  ],
  "properties": {
    "filename": {
      "type": "string",
      "description": "导出文件名，不包含扩展名"
    },
    "title": {
      "type": "string",
      "description": "数据标题（用于显示在表头上方，如果导出是Excel则是sheet名，如是csv则会忽略，其他文件格式会作为数据表格上方的标题）。支持国际化：使用 ${key} 占位符，导出时根据locale替换为对应文本"
    },
    "header-style": {
      "$ref": "#/definitions/Style",
      "description": "单表数据的通用表头样式定义"
    },
    "column-style": {
      "$ref": "#/definitions/Style",
      "description": "单表数据的通用单元格样式定义"
    },
    "columns": {
      "type": "object",
      "description": "列定义，key 为表字段名映射的类属性名，例如：表字段名为parent_code，映射的属性名为parentCode，使用parentCode",
      "additionalProperties": {
        "$ref": "#/definitions/Column"
      }
    }
  },
  "definitions": {
    "Style": {
      "type": "object",
      "properties": {
        "align": {
          "type": "string",
          "enum": [
            "HORIZONTAL",
            "CENTER",
            "LEFT",
            "RIGHT",
            "TOP",
            "BOTTOM",
            "FILL",
            "JUSTIFY",
            "DISTRIBUTED"
          ],
          "description": "对齐方式：HORIZONTAL - 默认水平对齐, CENTER - 居中对齐，可视为水平和垂直的居中, LEFT - 水平左对齐, RIGHT - 水平右对齐, TOP - 垂直上对齐, BOTTOM - 垂直下对齐, FILL - 水平填充对齐, JUSTIFY - 水平和垂直两端对齐, DISTRIBUTED - 水平和垂直分散对齐,"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色，暂只支持设置表头背景生效，十六进制 RGB 格式，如 #FFFFFF"
        },
        "font": {
          "type": "object",
          "description": "字体样式",
          "properties": {
            "family": {
              "type": "string",
              "description": "字体名称，如 Arial、Microsoft YaHei"
            },
            "size": {
              "type": "integer",
              "minimum": 1,
              "maximum": 72,
              "description": "字体大小，默认13"
            },
            "color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "字体颜色，十六进制 RGB 格式"
            },
            "bold": {
              "type": "boolean",
              "description": "是否加粗"
            },
            "italic": {
              "type": "boolean",
              "description": "是否斜体"
            }
          }
        },
        "border": {
          "type": "object",
          "description": "边框样式",
          "properties": {
            "color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "边框颜色"
            },
            "width": {
              "type": "string",
              "enum": [
                "NONE",
                "THIN",
                "MEDIUM",
                "THICK",
                "DOUBLE"
              ],
              "description": "边框宽度：NONE - 无边框，THIN - 细边框，MEDIUM - 中等边框，THICK - 粗边框，DOUBLE - 双边框"
            }
          }
        },
        "wrapped": {
          "type": "boolean",
          "description": "是否自动换行"
        }
      }
    },
    "Column": {
      "type": "object",
      "description": "表字段名映射的类属性名",
      "properties": {
        "header": {
          "type": "string",
          "description": "表头标题，可支持二级表头，使用':-:'分隔，例如：'成绩:-:语文'；只在 Markdown, Excel, PDF, HTML 格式文件导出时生效，其余格式只包含最后一级表头的输出。支持国际化：使用 ${key} 占位符，导出时根据locale替换为对应文本"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "列宽"
        },
        "when-null": {
          "type": "string",
          "description": "当数据为 null 时使用的默认值。支持国际化：使用 ${key} 占位符"
        },
        "when-blank": {
          "type": "string",
          "description": "当数据为空字符串时使用的默认值，仅适用于String类型。支持国际化：使用 ${key} 占位符"
        },
        "prefix": {
          "type": "string",
          "description": "最终值的文本前缀"
        },
        "suffix": {
          "type": "string",
          "description": "最终值的文本后缀"
        },
        "pattern": {
          "type": "object",
          "description": "数据格式化模式",
          "properties": {
            "date": {
              "type": "string",
              "description": "日期格式 pattern，如 yyyy-MM-dd HH:mm:ss。仅适用于日期时间类型"
            },
            "number": {
              "type": "string",
              "description": "数值格式 pattern，如 #,##0.00。仅适用于浮点类型或整数类型"
            }
          }
        },
        "converter": {
          "type": "object",
          "description": "数据转换器配置，配置一种即可，配置多个时，name方式的转换器优先级最低",
          "properties": {
            "enumerable": {
              "type": "string",
              "pattern": ".+#.+",
              "description": "将值转换为枚举类的特定属性值，无法转换的值将为'unknown'，格式为：枚举类全限定名#方法名，如 com.example.SomeEnum#getLabel，转换为枚举项的label属性值"
            },
            "named": {
              "type": "string",
              "description": "预置转换器名称，如 uppercase、lowercase、trim 等，具体名称参考具体接口实现，配置多个转换器使用英文分号分隔；需要传参数的情况，与调用Java方法的传参写法一致。支持国际化：参数中使用 ${key} 占位符"
            },
            "mapping": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "值映射表，格式为 原值:转换后值，如 1:男,2:女。支持国际化：映射值中使用 ${key} 占位符"
            }
          }
        },
        "style": {
          "$ref": "#/definitions/Style",
          "description": "此列的覆盖样式"
        }
      }
    }
  }
}
